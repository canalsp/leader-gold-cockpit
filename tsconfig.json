{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["api/**/*.ts", "lib/**/*.ts", "services/**/*.ts", "types/**/*.ts", "*.html", "public/**/*.js", "dev-server.ts", "load-env.ts"]
}
