MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
# Pode ficar vazio (ex.: root sem senha no XAMPP)
MYSQL_PASSWORD=
MYSQL_DATABASE=leader_old_site

# Tabela de origem no MySQL (legado). Colunas devem bater com types/post.ts
MYSQL_POSTS_TABLE=posts

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Tabela de destino no Supabase
SUPABASE_POSTS_TABLE=posts

# Auth mock (somente ambiente inicial)
COCKPIT_AUTH_USER=admin
COCKPIT_AUTH_PASSWORD=change-me
COCKPIT_AUTH_SECRET=change-this-secret
# mock | database
COCKPIT_AUTH_MODE=mock
# usado só no endpoint /api/auth/bootstrap para criar primeiro admin no modo database
# COCKPIT_BOOTSTRAP_SECRET=defina-um-segredo-forte

# Storage (bucket publico recomendado), ex.: post-images
SUPABASE_STORAGE_BUCKET=post-images

# CORS: origem do site em producao (ex.: https://www.leaderti.com.br). Local: deixe vazio para *.
# PUBLIC_SITE_ORIGIN=https://www.leaderti.com.br

# OpenAI — SEO no admin e chatbot publico do site (/api/public/chat)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# URL publica do site (links no pacote Instagram)
# PUBLIC_SITE_ORIGIN=https://www.leaderti.com.br

# Comentários e captcha
SUPABASE_COMMENTS_TABLE=post_comments
# COCKPIT_CAPTCHA_SECRET=defina-outro-segredo-forte
